{
  "name": "replays-fetcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "replays-fetcher": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsx src/cli.ts check",
    "format": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run format && npm run lint && npm run typecheck && npm test && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=25 <26"
  }
}
